{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "schema_id": "rules_v3_pass1_flat",
  "title": "Pass 1 Flat Decomposition Schema",
  "type": "object",
  "properties": {
    "trial_id": { "type": "string" },
    "criterion_type": {
      "type": "string",
      "enum": ["inclusion", "exclusion"]
    },
    "clauses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "clause_text": { "type": "string" },
          "evidence_text": { "type": "string" },
          "is_negated": { "type": "boolean" },
          "connector_to_next": {
            "type": ["string", "null"],
            "enum": ["AND", "OR", null]
          },
          "quantifier": {
            "type": ["object", "null"],
            "properties": {
              "quantifier_type": {
                "type": "string",
                "enum": ["AT_LEAST", "AT_MOST", "EXACTLY"]
              },
              "value": {
                "type": "integer",
                "minimum": 0
              }
            },
            "required": ["quantifier_type", "value"],
            "additionalProperties": false
          }
        },
        "required": [
          "clause_text",
          "evidence_text",
          "is_negated",
          "connector_to_next",
          "quantifier"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": ["trial_id", "criterion_type", "clauses"],
  "additionalProperties": false
}